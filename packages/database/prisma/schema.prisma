// Schema Prisma da Fase 2 (Plataforma Posto Barato).
//
// IMPORTANTE (seções 6, 7 e 8 da especificação):
//   - O schema `collector` pertence à Fase 1. Aqui ele é espelhado APENAS de
//     forma parcial e SOMENTE-LEITURA: declaramos exclusivamente os modelos e
//     campos públicos que a API pode ler.
//   - As tabelas sensíveis (collection_evidence, collection_errors,
//     collection_runs, collection_locks) e os campos sensíveis
//     (raw_visible_data, screenshot_path, html_snapshot_path, internal_name...)
//     NÃO são declarados aqui de propósito — a API não tem como acessá-los.
//   - As migrations do `collector` são de responsabilidade da Fase 1. A Fase 2
//     nunca altera tabelas do collector (aplicamos DDL apenas no schema `app`).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  schemas  = ["collector", "app"]
}

/// Fonte de dados (Fase 1). Somente `publicName` é exposto ao cliente final.
model DataSource {
  id           String             @id @db.Uuid
  internalName String             @unique @map("internal_name")
  publicName   String             @map("public_name")
  sourceType   String             @map("source_type")
  active       Boolean            @default(true)
  observations PriceObservation[]

  @@map("data_sources")
  @@schema("collector")
}

/// Posto identificado pela coleta (Fase 1). Leitura pública.
model Station {
  id                String             @id @db.Uuid
  displayName       String             @map("display_name")
  displayAddress    String             @map("display_address")
  neighborhood      String?
  municipality      String
  state             String
  postalCode        String?            @map("postal_code")
  latitude          Decimal?           @db.Decimal(9, 6)
  longitude         Decimal?           @db.Decimal(9, 6)
  active            Boolean            @default(true)
  firstSeenAt       DateTime           @map("first_seen_at")
  lastSeenAt        DateTime           @map("last_seen_at")
  observations      PriceObservation[]

  @@index([municipality, state])
  @@map("stations")
  @@schema("collector")
}

/// Produto canônico (Fase 1).
model Product {
  id            String             @id @db.Uuid
  canonicalCode String             @unique @map("canonical_code")
  canonicalName String             @map("canonical_name")
  category      String
  unit          String
  active        Boolean            @default(true)
  observations  PriceObservation[]

  @@map("products")
  @@schema("collector")
}

/// Observação de preço (Fase 1). Expomos apenas campos públicos derivados;
/// raw_visible_data e evidence_id NÃO são declarados aqui.
model PriceObservation {
  id                  String     @id @db.Uuid
  stationId           String     @map("station_id") @db.Uuid
  productId           String     @map("product_id") @db.Uuid
  dataSourceId        String     @map("data_source_id") @db.Uuid
  priceDecimal        Decimal    @map("price_decimal") @db.Decimal(10, 3)
  currency            String     @default("BRL")
  unit                String     @default("L")
  relativeTimeText    String?    @map("relative_time_text")
  estimatedObservedAt DateTime?  @map("estimated_observed_at")
  estimatedTime       Boolean    @default(false) @map("estimated_time")
  collectedAt         DateTime   @map("collected_at")
  sourcePosition      Int        @map("source_position")
  confidenceScore     Decimal    @default(1) @map("confidence_score") @db.Decimal(3, 2)
  station             Station    @relation(fields: [stationId], references: [id])
  product             Product    @relation(fields: [productId], references: [id])
  dataSource          DataSource @relation(fields: [dataSourceId], references: [id])

  @@index([stationId])
  @@index([productId])
  @@index([collectedAt])
  @@map("price_observations")
  @@schema("collector")
}

// ---------------------------------------------------------------------------
// Schema `app` — pertence à Fase 2.
// ---------------------------------------------------------------------------

/// Marca quais postos são dados demonstrativos (seed), para rotular
/// "Dados demonstrativos" no cliente (seção 35). is_demo nunca deve misturar-se
/// silenciosamente com dados reais em produção.
model DemoStation {
  stationId String   @id @map("station_id") @db.Uuid
  note      String?
  createdAt DateTime @default(now()) @map("created_at")

  @@map("demo_stations")
  @@schema("app")
}

/// Conta do cliente final. Sem multi-tenant — cada usuário é a própria conta.
/// `premiumSince` é a fonte única de verdade do gate de acesso: não nulo ==
/// Premium vitalício (comprado uma única vez, seção "assinatura vitalícia").
model User {
  id            String         @id @default(uuid()) @db.Uuid
  email         String         @unique
  passwordHash  String         @map("password_hash")
  name          String?
  premiumSince  DateTime?      @map("premium_since")
  createdAt     DateTime       @default(now()) @map("created_at")
  updatedAt     DateTime       @updatedAt @map("updated_at")
  refreshTokens RefreshToken[]
  purchases     Purchase[]

  @@map("users")
  @@schema("app")
}

/// Refresh token opaco (rotativo). Armazena apenas o hash — nunca o token cru.
/// Revogação individual (`revokedAt`) e encadeamento (`replacedById`) permitem
/// detectar reuso de token roubado (seção 14: refresh token rotativo).
model RefreshToken {
  id           String    @id @default(uuid()) @db.Uuid
  userId       String    @map("user_id") @db.Uuid
  user         User      @relation(fields: [userId], references: [id])
  tokenHash    String    @unique @map("token_hash")
  createdAt    DateTime  @default(now()) @map("created_at")
  expiresAt    DateTime  @map("expires_at")
  revokedAt    DateTime? @map("revoked_at")
  replacedById String?   @map("replaced_by_id") @db.Uuid

  @@index([userId])
  @@map("refresh_tokens")
  @@schema("app")
}

enum PurchaseStatus {
  PENDING
  PAID
  FAILED
  REFUNDED

  @@schema("app")
}

/// Compra única do Premium vitalício (R$ 9,99, sem recorrência). O
/// pagamento real acontece via Asaas (Checkout hospedado, chargeType
/// DETACHED); em desenvolvimento sem ASAAS_API_KEY o fluxo roda simulado.
model Purchase {
  id                 String         @id @default(uuid()) @db.Uuid
  userId             String         @map("user_id") @db.Uuid
  user               User           @relation(fields: [userId], references: [id])
  amountCents        Int            @map("amount_cents")
  currency           String         @default("BRL")
  status             PurchaseStatus @default(PENDING)
  provider           String         @default("asaas")
  providerCheckoutId String?        @map("provider_checkout_id")
  providerPaymentId  String?        @map("provider_payment_id")
  paidAt             DateTime?      @map("paid_at")
  createdAt          DateTime       @default(now()) @map("created_at")
  updatedAt          DateTime       @updatedAt @map("updated_at")

  @@index([userId])
  @@index([providerCheckoutId])
  @@index([providerPaymentId])
  @@map("purchases")
  @@schema("app")
}
