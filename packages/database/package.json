{
  "name": "@posto-barato/database",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "generate": "prisma generate",
    "validate": "prisma validate",
    "migrate": "tsx src/migrate.ts",
    "seed": "tsx prisma/seed.ts",
    "reset": "tsx src/migrate.ts --reset && tsx prisma/seed.ts",
    "refresh": "tsx src/refresh.ts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src prisma"
  },
  "dependencies": {
    "@prisma/client": "^6.12.0",
    "pg": "^8.13.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "@types/pg": "^8.11.10",
    "prisma": "^6.12.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
