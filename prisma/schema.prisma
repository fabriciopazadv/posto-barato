generator client { provider = "prisma-client-js" }
datasource db { provider = "postgresql" url = env("DATABASE_URL") schemas = ["collector"] }

enum CollectionRunStatus { RUNNING SUCCESS PARTIAL_SUCCESS FAILED AUTH_REQUIRED BLOCKED CAPTCHA_DETECTED SECURITY_CHALLENGE PAGE_CHANGED @@schema("collector") }

model DataSource { id String @id @default(uuid()) @db.Uuid internalName String @unique @map("internal_name") publicName String @map("public_name") sourceType String @map("source_type") active Boolean @default(true) createdAt DateTime @default(now()) @map("created_at") updatedAt DateTime @updatedAt @map("updated_at") observations PriceObservation[] @@map("data_sources") @@schema("collector") }
model CollectionRun { id String @id @default(uuid()) @db.Uuid startedAt DateTime @default(now()) @map("started_at") finishedAt DateTime? @map("finished_at") status CollectionRunStatus @default(RUNNING) municipality String state String productsRequested Json @map("products_requested") totalCardsFound Int @default(0) @map("total_cards_found") totalRecordsCreated Int @default(0) @map("total_records_created") totalDuplicates Int @default(0) @map("total_duplicates") totalInvalid Int @default(0) @map("total_invalid") totalErrors Int @default(0) @map("total_errors") screenshotPath String? @map("screenshot_path") htmlSnapshotPath String? @map("html_snapshot_path") errorMessage String? @map("error_message") browserVersion String? @map("browser_version") collectorVersion String @map("collector_version") hostName String @map("host_name") createdAt DateTime @default(now()) @map("created_at") observations PriceObservation[] errors CollectionError[] evidences CollectionEvidence[] @@index([municipality,state]) @@index([status]) @@map("collection_runs") @@schema("collector") }
model Station { id String @id @default(uuid()) @db.Uuid normalizedName String @map("normalized_name") displayName String @map("display_name") normalizedAddress String @map("normalized_address") displayAddress String @map("display_address") neighborhood String? municipality String state String postalCode String? @map("postal_code") latitude Decimal? @db.Decimal(9,6) longitude Decimal? @db.Decimal(9,6) fingerprint String @unique active Boolean @default(true) firstSeenAt DateTime @map("first_seen_at") lastSeenAt DateTime @map("last_seen_at") createdAt DateTime @default(now()) @map("created_at") updatedAt DateTime @updatedAt @map("updated_at") observations PriceObservation[] @@index([municipality,state]) @@index([fingerprint]) @@map("stations") @@schema("collector") }
model Product { id String @id @default(uuid()) @db.Uuid canonicalCode String @unique @map("canonical_code") canonicalName String @map("canonical_name") category String unit String active Boolean @default(true) createdAt DateTime @default(now()) @map("created_at") updatedAt DateTime @updatedAt @map("updated_at") observations PriceObservation[] @@map("products") @@schema("collector") }
model PriceObservation { id String @id @default(uuid()) @db.Uuid stationId String @map("station_id") @db.Uuid productId String @map("product_id") @db.Uuid dataSourceId String @map("data_source_id") @db.Uuid collectionRunId String @map("collection_run_id") @db.Uuid originalProductName String @map("original_product_name") originalPriceText String @map("original_price_text") priceDecimal Decimal @map("price_decimal") @db.Decimal(10,3) currency String @default("BRL") unit String @default("L") relativeTimeText String? @map("relative_time_text") estimatedObservedAt DateTime? @map("estimated_observed_at") estimatedTime Boolean @default(false) @map("estimated_time") collectedAt DateTime @map("collected_at") sourcePosition Int @map("source_position") confidenceScore Decimal @default(1) @map("confidence_score") @db.Decimal(3,2) observationFingerprint String @unique @map("observation_fingerprint") rawVisibleData Json @map("raw_visible_data") evidenceId String? @map("evidence_id") @db.Uuid createdAt DateTime @default(now()) @map("created_at") station Station @relation(fields:[stationId],references:[id]) product Product @relation(fields:[productId],references:[id]) dataSource DataSource @relation(fields:[dataSourceId],references:[id]) collectionRun CollectionRun @relation(fields:[collectionRunId],references:[id]) evidence CollectionEvidence? @relation(fields:[evidenceId],references:[id]) @@index([stationId]) @@index([productId]) @@index([priceDecimal]) @@index([collectedAt]) @@index([estimatedObservedAt]) @@index([collectionRunId]) @@map("price_observations") @@schema("collector") }
model CollectionError { id String @id @default(uuid()) @db.Uuid collectionRunId String @map("collection_run_id") @db.Uuid stage String errorType String @map("error_type") message String details Json? screenshotPath String? @map("screenshot_path") createdAt DateTime @default(now()) @map("created_at") collectionRun CollectionRun @relation(fields:[collectionRunId],references:[id]) @@map("collection_errors") @@schema("collector") }
model CollectionEvidence { id String @id @default(uuid()) @db.Uuid collectionRunId String @map("collection_run_id") @db.Uuid evidenceType String @map("evidence_type") filePath String @map("file_path") sha256 String containsPersonalHeader Boolean @default(false) @map("contains_personal_header") collectedAt DateTime @map("collected_at") expiresAt DateTime? @map("expires_at") createdAt DateTime @default(now()) @map("created_at") collectionRun CollectionRun @relation(fields:[collectionRunId],references:[id]) observations PriceObservation[] @@map("collection_evidence") @@schema("collector") }
model CollectionLock { id String @id @default(uuid()) @db.Uuid lockName String @unique @map("lock_name") acquiredAt DateTime @map("acquired_at") expiresAt DateTime @map("expires_at") ownerId String @map("owner_id") @@map("collection_locks") @@schema("collector") }
