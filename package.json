{
  "name": "posto-barato",
  "version": "0.2.0",
  "private": true,
  "description": "Plataforma Posto Barato — Fase 2 (API pública de leitura + clientes)",
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@10.33.0",
  "pnpm": {
    "onlyBuiltDependencies": ["@prisma/client", "prisma", "@prisma/engines", "esbuild", "argon2"]
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "dev:api": "pnpm --filter @posto-barato/api dev",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "db:generate": "pnpm --filter @posto-barato/database generate",
    "db:migrate": "pnpm --filter @posto-barato/database migrate",
    "db:seed": "pnpm --filter @posto-barato/database seed",
    "db:reset": "pnpm --filter @posto-barato/database reset",
    "docker:up": "docker compose up -d postgres redis",
    "docker:down": "docker compose down"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "eslint": "^9.17.0",
    "globals": "^15.14.0",
    "prettier": "^3.4.2",
    "turbo": "^2.3.3",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.19.0"
  }
}
