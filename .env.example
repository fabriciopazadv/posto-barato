# =============================================================================
# Posto Barato — Fase 2 (variáveis de ambiente). Copie para .env e ajuste.
# NUNCA coloque credenciais reais aqui. Este arquivo é versionado.
# =============================================================================

# --- Banco de dados -----------------------------------------------------------
# Em produção, use usuários distintos por responsabilidade (ver docs/security/).
#   migration_admin → migrações   |   api_reader → leitura   |   app_writer → escrita
DATABASE_URL=postgresql://posto_barato:posto_barato@localhost:5432/posto_barato

# A API deveria usar um usuário SOMENTE-LEITURA em produção:
DATABASE_READONLY_URL=postgresql://api_reader:changeme@localhost:5432/posto_barato

# Não aplica o bootstrap do schema `collector` (use em produção, onde a Fase 1 o mantém).
SKIP_COLLECTOR_BOOTSTRAP=false

# --- Redis (cache — próximos incrementos) ------------------------------------
REDIS_URL=redis://localhost:6379

# --- API ----------------------------------------------------------------------
NODE_ENV=development
API_PORT=3333
API_HOST=0.0.0.0
LOG_LEVEL=info
CORS_ORIGIN=*

# Faixas de frescor do preço (horas) — RECENT/MODERATE/OLD/EXPIRED (seção 8).
FRESHNESS_RECENT_HOURS=6
FRESHNESS_MODERATE_HOURS=24
FRESHNESS_OLD_HOURS=72

# Limites de consulta e rate limit (seções 10, 30).
MAX_PAGE_SIZE=50
MAX_RADIUS_KM=50
RATE_LIMIT_MAX=120
RATE_LIMIT_WINDOW=1 minute

# Localidade padrão e modo demonstração (seção 35).
DEFAULT_MUNICIPALITY=Rondonópolis
DEFAULT_STATE=MT
DEMO_MODE=true

# --- Feature flags (seção 28/36) ---------------------------------------------
FEATURE_CHARGING_STATIONS=false

# --- Autenticação (seção 14) --------------------------------------------------
# Gere um segredo forte (>= 32 caracteres), ex.: openssl rand -base64 48
AUTH_ACCESS_SECRET=troque-por-um-segredo-forte-de-pelo-menos-32-caracteres
AUTH_ACCESS_TOKEN_TTL_SECONDS=900
AUTH_REFRESH_TOKEN_TTL_DAYS=30
# false em desenvolvimento local sem HTTPS; true em produção.
COOKIE_SECURE=true

# URL pública usada nos callbacks de checkout do Asaas.
APP_URL=http://localhost:3333

# --- Premium vitalício (pagamento único via Asaas) ----------------------------
# Sem ASAAS_API_KEY: checkout roda em modo simulado (confirma a compra na hora,
# útil para desenvolvimento/demonstração — nenhuma cobrança real acontece).
PREMIUM_PRICE_CENTS=999
PREMIUM_LABEL=Posto Barato Premium
ASAAS_API_KEY=
ASAAS_ENV=sandbox
# Header "asaas-access-token" esperado no webhook (docs.asaas.com/docs/mecanismo-para-validacao-de-saque-via-webhooks).
ASAAS_WEBHOOK_TOKEN=

# --- Placeholders para próximos incrementos (ainda não usados) ----------------
# MAP_PROVIDER=
# MAP_API_KEY=
# EMAIL_PROVIDER=
# STORAGE_PROVIDER=
# SENTRY_DSN=
