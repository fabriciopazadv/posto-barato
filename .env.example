DATABASE_URL=postgresql://posto_barato:posto_barato@localhost:5432/posto_barato?schema=collector
NOTA_MT_BASE_URL=https://www.nota.mt.gov.br
NOTA_MT_MENOR_PRECO_URL=https://www.nota.mt.gov.br/menor-preco
BROWSER_PROFILE_DIR=./storage/browser-profile
EVIDENCE_DIR=./storage/evidence
HTML_SNAPSHOT_DIR=./storage/html-snapshots
LOG_DIR=./storage/logs
LOCK_DIR=./storage/locks
LOG_LEVEL=info
HEADLESS=false
DEFAULT_MUNICIPALITY=Rondonópolis
DEFAULT_STATE=MT
COLLECTION_PRODUCTS=etanol,gasolina comum,gasolina aditivada,diesel comum,diesel s10
MAX_LOAD_MORE_CLICKS=30
ACTION_DELAY_MIN_MS=800
ACTION_DELAY_MAX_MS=1800
COLLECTION_TIMEOUT_MS=180000
SAVE_SCREENSHOTS=true
SAVE_HTML_SNAPSHOTS=true
EVIDENCE_RETENTION_DAYS=90
COLLECTION_FREQUENCY_HOURS=4
SCHEDULER_ENABLED=false
