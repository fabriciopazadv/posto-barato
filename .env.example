# =============================================================================
# Posto Barato — Fase 2 (variáveis de ambiente). Copie para .env e ajuste.
# NUNCA coloque credenciais reais aqui. Este arquivo é versionado.
# =============================================================================

# --- Banco de dados -----------------------------------------------------------
# Em produção, use usuários distintos por responsabilidade (ver docs/security/).
#   migration_admin → migrações   |   api_reader → leitura   |   app_writer → escrita
DATABASE_URL=postgresql://posto_barato:posto_barato@localhost:5432/posto_barato

# A API deveria usar um usuário SOMENTE-LEITURA em produção:
DATABASE_READONLY_URL=postgresql://api_reader:changeme@localhost:5432/posto_barato

# Não aplica o bootstrap do schema `collector` (use em produção, onde a Fase 1 o mantém).
SKIP_COLLECTOR_BOOTSTRAP=false

# --- Redis (cache — próximos incrementos) ------------------------------------
REDIS_URL=redis://localhost:6379

# --- API ----------------------------------------------------------------------
NODE_ENV=development
API_PORT=3333
API_HOST=0.0.0.0
LOG_LEVEL=info
CORS_ORIGIN=*

# Faixas de frescor do preço (horas) — RECENT/MODERATE/OLD/EXPIRED (seção 8).
FRESHNESS_RECENT_HOURS=6
FRESHNESS_MODERATE_HOURS=24
FRESHNESS_OLD_HOURS=72

# Limites de consulta e rate limit (seções 10, 30).
MAX_PAGE_SIZE=50
MAX_RADIUS_KM=50
RATE_LIMIT_MAX=120
RATE_LIMIT_WINDOW=1 minute

# Localidade padrão e modo demonstração (seção 35).
DEFAULT_MUNICIPALITY=Rondonópolis
DEFAULT_STATE=MT
DEMO_MODE=true

# --- Feature flags (seção 28/36) ---------------------------------------------
FEATURE_CHARGING_STATIONS=false

# --- Placeholders para próximos incrementos (ainda não usados) ----------------
# JWT_SECRET=
# JWT_REFRESH_SECRET=
# MAP_PROVIDER=
# MAP_API_KEY=
# PAYMENT_PROVIDER=mock
# PAYMENT_WEBHOOK_SECRET=
# EMAIL_PROVIDER=
# STORAGE_PROVIDER=
# SENTRY_DSN=
